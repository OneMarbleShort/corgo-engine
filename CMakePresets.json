{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-sim",
      "displayName": "VS2022 Simulator",
      "description": "Simulator configure using Visual Studio 2022 generator.",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build.vs2022",
      "hidden":true
    },
    {
      "name": "pd-debug",
      "displayName": "Playdate Device Debug",
      "description": "Playdate ARM debug configure using arm toolchain. Requires NMAKE_PATH env var (run 'Device: configure (Debug)' task once to set it).",
      "generator": "NMake Makefiles",
      "binaryDir": "${sourceDir}/build.pd",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MAKE_PROGRAM": "$penv{NMAKE_PATH}",
        "CMAKE_TOOLCHAIN_FILE": "${env:PLAYDATE_SDK_PATH}/C_API/buildsupport/arm.cmake"
      },
      "hidden":true
    },
    {
      "name": "pd-release",
      "displayName": "Playdate Device Release",
      "description": "Playdate ARM release configure using arm toolchain. Requires NMAKE_PATH env var (run 'Device: configure (Debug)' task once to set it).",
      "generator": "NMake Makefiles",
      "binaryDir": "${sourceDir}/build.pd.release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MAKE_PROGRAM": "$penv{NMAKE_PATH}",
        "CMAKE_TOOLCHAIN_FILE": "${env:PLAYDATE_SDK_PATH}/C_API/buildsupport/arm.cmake"
      },
      "hidden":true
    },
    {
      "name": "game-vs2022-sim",
      "displayName": "VS2022 Simulator (game)",
      "description": "Builds src/game/ — the default blank game template. To add your own game, duplicate this preset, change CE_GAME_NAME and binaryDir to match your src/<name>/ directory.",
      "inherits": "vs2022-sim",
      "binaryDir": "${sourceDir}/build.vs2022.game",
      "cacheVariables": {
        "CE_GAME_NAME": "game"
      }
    },
    {
      "name": "samples-vs2022-sim",
      "displayName": "VS2022 Simulator (samples)",
      "description": "Builds src/samples/ — the built-in engine samples collection.",
      "inherits": "vs2022-sim",
      "binaryDir": "${sourceDir}/build.vs2022.samples",
      "cacheVariables": {
        "CE_GAME_NAME": "samples"
      }
    },
    {
      "name": "game-pd-debug",
      "displayName": "Playdate Device Debug (game)",
      "description": "Builds src/game/ for Playdate device debug.",
      "inherits": "pd-debug",
      "binaryDir": "${sourceDir}/build.pd.game",
      "cacheVariables": {
        "CE_GAME_NAME": "game"
      }
    },
    {
      "name": "samples-pd-debug",
      "displayName": "Playdate Device Debug (samples)",
      "description": "Builds src/samples/ for Playdate device debug.",
      "inherits": "pd-debug",
      "binaryDir": "${sourceDir}/build.pd.samples",
      "cacheVariables": {
        "CE_GAME_NAME": "samples"
      }
    },
    {
      "name": "game-pd-release",
      "displayName": "Playdate Device Release (game)",
      "description": "Builds src/game/ for Playdate device release.",
      "inherits": "pd-release",
      "binaryDir": "${sourceDir}/build.pd.release.game",
      "cacheVariables": {
        "CE_GAME_NAME": "game"
      }
    },
    {
      "name": "samples-pd-release",
      "displayName": "Playdate Device Release (samples)",
      "description": "Builds src/samples/ for Playdate device release.",
      "inherits": "pd-release",
      "binaryDir": "${sourceDir}/build.pd.release.samples",
      "cacheVariables": {
        "CE_GAME_NAME": "samples"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-vs2022-sim",
      "displayName": "Build VS2022 Simulator",
      "configurePreset": "vs2022-sim",
      "configuration": "Debug"
    },
    {
      "name": "build-game-vs2022-sim",
      "displayName": "Build VS2022 Simulator (game)",
      "configurePreset": "game-vs2022-sim",
      "configuration": "Debug"
    },
    {
      "name": "build-samples-vs2022-sim",
      "displayName": "Build VS2022 Simulator (samples)",
      "configurePreset": "samples-vs2022-sim",
      "configuration": "Debug"
    },
    {
      "name": "build-pd-debug",
      "displayName": "Build Playdate Device Debug",
      "configurePreset": "pd-debug"
    },
    {
      "name": "build-game-pd-debug",
      "displayName": "Build Playdate Device Debug (game)",
      "configurePreset": "game-pd-debug"
    },
    {
      "name": "build-samples-pd-debug",
      "displayName": "Build Playdate Device Debug (samples)",
      "configurePreset": "samples-pd-debug"
    },
    {
      "name": "build-pd-release",
      "displayName": "Build Playdate Device Release",
      "configurePreset": "pd-release"
    },
    {
      "name": "build-game-pd-release",
      "displayName": "Build Playdate Device Release (game)",
      "configurePreset": "game-pd-release"
    },
    {
      "name": "build-samples-pd-release",
      "displayName": "Build Playdate Device Release (samples)",
      "configurePreset": "samples-pd-release"
    }
  ],
  "testPresets": [
    {
      "name": "test-core-vs2022",
      "displayName": "Run CoreTests (VS2022)",
      "configurePreset": "vs2022-sim",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
